{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "functions": {
    "api/engine.js": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/engine" },
    { "source": "/((?!api/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
